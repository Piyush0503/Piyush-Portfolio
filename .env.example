# MongoDB connection string (Atlas or local)
# Example: mongodb+srv://user:pass@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=

# Optional database name (default: portfolio)
MONGODB_DB=portfolio

# ── Email Notification (Gmail + Nodemailer) ─────────────────────
# Generate a Gmail App Password (NOT your normal password):
#   Google Account → Security → 2-Step Verification → App Passwords
#   Select app: "Mail", device: "Other" → copy the 16-char password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
NOTIFY_EMAIL=your_email@gmail.com
